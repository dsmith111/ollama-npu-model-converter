{
  "workflow_id": "npu_model_{{ family }}_qnn_llm",
  "input_model": {
    "type": "OnnxModel",
    "config": {
      "model_path": {{ input_model_path }},
      "tokenizer_path": {{ tokenizer_dir }}
    }
  },
  "systems": {
    "local_system": {
      "type": "LocalSystem",
      "accelerators": [
        {
          "device": "cpu",
          "execution_providers": [
            "QNNExecutionProvider"
          ]
        }
      ]
    }
  },
  "passes": {
    "capture_split_info": {
      "type": "CaptureSplitInfo"
    },
    "static_llm": {
      "type": "StaticLLM"
    },
    "onnx_quantization_preprocess": {
      "type": "OnnxQuantizationPreprocess"
    }
  },
  "engine": {
    "host": "local_system",
    "target": "local_system",
    "execution_providers": [
      "QNNExecutionProvider"
    ]
  },
  "output_dir": {{ output_dir }}
}

